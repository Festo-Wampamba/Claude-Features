{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/festo/.claude/hooks/ui-ux-pro-max-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading UI/UX Pro Max skill..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/festo/.claude/hooks/karpathy-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading Karpathy Guidelines..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/festo/.claude/hooks/compact-reminder.sh",
            "timeout": 5,
            "statusMessage": "Restoring context..."
          }
        ],
        "matcher": "compact"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/festo/.claude/hooks/session-start.sh",
            "timeout": 10,
            "statusMessage": "Loading project context..."
          }
        ],
        "matcher": "startup|resume"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/festo/.claude/hooks/ui-ux-pro-max-prompt.js\"",
            "timeout": 5,
            "statusMessage": "Checking UI/UX context..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/festo/.claude/hooks/notify.sh",
            "timeout": 10,
            "statusMessage": "Notifying..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/festo/.claude/hooks/protect-files.sh",
            "timeout": 10,
            "statusMessage": "Checking file protections..."
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/festo/.claude/hooks/scan-secrets.sh",
            "timeout": 10,
            "statusMessage": "Scanning for secrets..."
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/festo/.claude/hooks/block-dangerous-commands.sh",
            "timeout": 10,
            "statusMessage": "Checking command safety..."
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/festo/.claude/hooks/format-on-save.sh",
            "timeout": 30,
            "statusMessage": "Formatting..."
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/festo/.claude/hooks/auto-test.sh",
            "timeout": 120,
            "statusMessage": "Running matching tests..."
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/festo/.claude/hooks/sync-claude-features.sh",
            "timeout": 30,
            "statusMessage": "Syncing to GitHub..."
          }
        ]
      }
    ]
  },
